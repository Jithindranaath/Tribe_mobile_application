{
  "name": "tribe-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json && mkdir -p dist/idl && cp src/idl/tribe.json dist/idl/tribe.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "ws": "^8.16.0",
    "eventsource": "^2.0.0",
    "@supabase/supabase-js": "^2.42.0",
    "@solana/web3.js": "^1.91.0",
    "@coral-xyz/anchor": "^0.30.0",
    "satori": "^0.10.0",
    "@resvg/resvg-js": "^2.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/eventsource": "^1.1.15",
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "fast-check": "^3.17.0"
  }
}
