# Supabase (Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# TxLINE wallet (backend service wallet for data subscription)
# Generate with: npx tsx server/scripts/generate-wallet.ts
# Value is a JSON array of 64 bytes (Solana secret key)
TXLINE_WALLET_KEYPAIR=[your-json-byte-array-keypair]

# Anthropic Claude API (Keeper AI)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# TxLINE API (populated after activation flow)
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
ANCHOR_PROGRAM_ID=your-deployed-program-id

# Privy (embedded identity — silent wallet creation)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# App
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
